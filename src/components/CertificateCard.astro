---
import { text } from "../lib/i18n";
import { withBase } from "../lib/url";
import type { Locale, PartialLocalizedText } from "../data/site";

interface Props {
  id: string;
  title: PartialLocalizedText;
  issuer: string;
  locale: Locale;
  image?: string;
  file?: string;
  status?: PartialLocalizedText;
  publicNumber?: string;
}

const { id, title, issuer, image, file, status, publicNumber, locale } = Astro.props;
const dialogId = `certificate-${id}`;
---

<article class="group rounded-lg border border-ink/10 bg-white p-4 shadow-sm transition hover:-translate-y-1 hover:shadow-soft" data-certificate-card>
  <button
    type="button"
    data-certificate-open={dialogId}
    class="block w-full rounded-md border border-ink/10 bg-paper p-3 text-left transition group-hover:border-leaf-700"
    aria-label={`${locale === "te" ? "పత్రాన్ని తెరవండి" : "Open document"}: ${text(title, locale)}`}
  >
    {image ? (
      <img src={withBase(image)} alt={text(title, locale)} width="720" height="960" loading="lazy" class="mx-auto aspect-[3/4] max-h-72 w-full rounded-sm object-contain" />
    ) : (
      <span class="flex aspect-[3/4] items-center justify-center rounded-sm bg-sand-100 text-center text-sm font-extrabold text-ink/55">
        {locale === "te" ? "పత్రం త్వరలో" : "Document pending"}
      </span>
    )}
  </button>
  <div class="pt-4">
    <h3 class="text-xl font-black leading-tight text-ink">{text(title, locale)}</h3>
    <p class="mt-2 text-sm font-semibold text-ink/62">{issuer}</p>
    {publicNumber && <p class="mt-3 rounded-md bg-leaf-50 px-3 py-2 text-xs font-extrabold text-leaf-900">{locale === "te" ? "పబ్లిక్ సంఖ్య: " : "Public number: "}{publicNumber}</p>}
    {status && <p class="mt-3 text-sm leading-6 text-ink/68">{text(status, locale)}</p>}
    {file && (
      <a href={withBase(file)} class="mt-4 inline-flex rounded-md border border-leaf-700 px-4 py-2 text-sm font-extrabold text-leaf-700 hover:bg-leaf-50">
        {locale === "te" ? "స్కాన్ తెరవండి" : "Open scan"}
      </a>
    )}
  </div>
  {image && (
    <dialog id={dialogId} data-certificate-dialog class="max-h-[92vh] w-[min(920px,calc(100%-24px))] rounded-lg border border-ink/10 bg-white p-0 text-ink shadow-soft backdrop:bg-ink/75">
      <div class="flex items-center justify-between gap-4 border-b border-ink/10 px-4 py-3">
        <div>
          <p class="text-sm font-extrabold text-ink">{text(title, locale)}</p>
          <p class="text-xs font-semibold text-ink/58">{issuer}</p>
        </div>
        <form method="dialog">
          <button class="rounded-md border border-ink/15 px-3 py-2 text-sm font-extrabold hover:bg-sand-50">
            {locale === "te" ? "మూసివేయండి" : "Close"}
          </button>
        </form>
      </div>
      <div class="max-h-[78vh] overflow-auto bg-paper p-4">
        <img src={withBase(image)} alt={text(title, locale)} width="960" height="1280" class="mx-auto max-h-[74vh] w-auto rounded-sm bg-white object-contain shadow-sm" loading="lazy" />
      </div>
    </dialog>
  )}
</article>

<script>
  document.addEventListener("click", (event) => {
    const openButton = event.target instanceof Element ? event.target.closest("[data-certificate-open]") : null;
    if (openButton) {
      const dialog = document.getElementById(openButton.getAttribute("data-certificate-open") || "");
      if (dialog instanceof HTMLDialogElement) dialog.showModal();
    }

    const dialog = event.target instanceof Element ? event.target.closest("[data-certificate-dialog]") : null;
    if (event.target === dialog && dialog instanceof HTMLDialogElement) dialog.close();
  });
</script>
