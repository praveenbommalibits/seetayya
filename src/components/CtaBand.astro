---
import { localizePath, text } from "../lib/i18n";
import { ui, type Locale, type PartialLocalizedText } from "../data/site";

interface Props {
  locale: Locale;
  eyebrow: PartialLocalizedText;
  title: PartialLocalizedText;
  body: PartialLocalizedText;
  primaryPath?: string;
  secondaryPath?: string;
}

const {
  locale,
  eyebrow,
  title,
  body,
  primaryPath = "/donate",
  secondaryPath = "/sponsor-a-day"
} = Astro.props;
---

<section class="border-y border-leaf-700/10 bg-leaf-900 py-14 text-white">
  <div class="container-pad grid gap-8 md:grid-cols-[1.3fr_0.7fr] md:items-center">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-saffron-100">{text(eyebrow, locale)}</p>
      <h2 class="mt-3 text-3xl font-extrabold leading-tight md:text-4xl">{text(title, locale)}</h2>
      <p class="mt-4 max-w-2xl text-white/78">{text(body, locale)}</p>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row md:flex-col">
      <a href={localizePath(locale, primaryPath)} class="inline-flex items-center justify-center rounded-md bg-saffron-500 px-5 py-3 text-sm font-extrabold text-ink transition hover:bg-saffron-100">
        {text(ui.donateNow, locale)}
      </a>
      <a href={localizePath(locale, secondaryPath)} class="inline-flex items-center justify-center rounded-md border border-white/35 px-5 py-3 text-sm font-extrabold text-white transition hover:bg-white/10">
        {text(ui.sponsorDay, locale)}
      </a>
    </div>
  </div>
</section>
