---
interface Localized {
  en: string;
  te?: string;
}

interface Props {
  href: string;
  title: Localized;
  summary: Localized;
  date: Date;
  category: string;
  image: string;
}

const { href, title, summary, date, category, image } = Astro.props;
const dateText = date.toLocaleDateString("en-IN", {
  day: "numeric",
  month: "short",
  year: "numeric"
});
---

<article class="group overflow-hidden rounded-lg border border-ink/10 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
  <a href={href} class="block">
    <div class="aspect-[4/3] overflow-hidden bg-leaf-50">
      <img src={image} alt={title.en} loading="lazy" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
    </div>
    <div class="space-y-3 p-5">
      <div class="flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-wide text-leaf-700">
        <span>{category}</span>
        <span aria-hidden="true">/</span>
        <time datetime={date.toISOString()}>{dateText}</time>
      </div>
      <h3 class="text-xl font-extrabold leading-tight text-ink">{title.en}</h3>
      {title.te && <p class="telugu text-sm font-semibold text-ink/70">{title.te}</p>}
      <p class="line-clamp-3 text-sm leading-6 text-ink/70">{summary.en}</p>
    </div>
  </a>
</article>
