---
import { formatCurrency, text } from "../lib/i18n";
import type { Locale, PartialLocalizedText } from "../data/site";

interface Props {
  amount: number;
  title: PartialLocalizedText;
  impact: PartialLocalizedText;
  featured?: boolean;
  locale: Locale;
}

const { amount, title, impact, featured = false, locale } = Astro.props;
---

<button
  type="button"
  data-amount={amount}
  class:list={[
    "donation-tier rounded-lg border p-4 text-left transition hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-4 focus-visible:outline-saffron-500",
    featured ? "border-saffron-500 bg-saffron-50 shadow-soft" : "border-ink/10 bg-white hover:border-leaf-700"
  ]}
>
  <span class="block text-2xl font-black text-ink">{formatCurrency(amount, locale)}</span>
  <span class="mt-2 block text-sm font-extrabold text-leaf-700">{text(title, locale)}</span>
  <span class="mt-2 block text-sm leading-6 text-ink/68">{text(impact, locale)}</span>
</button>
