---
import { withBase } from "../lib/url";

interface Photo {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {photos.map((photo) => (
    <figure class="overflow-hidden rounded-lg border border-ink/10 bg-white shadow-sm">
      <div class="aspect-[4/3] bg-leaf-50">
        <img src={withBase(photo.src)} alt={photo.alt} loading="lazy" class="h-full w-full object-cover" />
      </div>
      {photo.caption && <figcaption class="px-4 py-3 text-sm leading-6 text-ink/70">{photo.caption}</figcaption>}
    </figure>
  ))}
</div>
