---
import { text } from "../lib/i18n";
import { withBase } from "../lib/url";
import type { Locale, PartialLocalizedText } from "../data/site";

interface Props {
  id: string;
  title: PartialLocalizedText;
  eyebrow: PartialLocalizedText;
  summary: PartialLocalizedText;
  details: PartialLocalizedText;
  image: string;
  locale: Locale;
}

const { id, title, eyebrow, summary, details, image, locale } = Astro.props;
---

<article id={id} class="group grid overflow-hidden rounded-lg border border-ink/10 bg-white shadow-sm md:grid-cols-[0.78fr_1.22fr]">
  <div class="aspect-[4/3] bg-sand-100 md:aspect-auto">
    <img src={withBase(image)} alt={text(title, locale)} loading="lazy" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
  </div>
  <div class="p-6">
    <p class="text-xs font-extrabold uppercase tracking-[0.18em] text-terracotta-700">{text(eyebrow, locale)}</p>
    <h2 class="mt-3 text-2xl font-black leading-tight text-ink">{text(title, locale)}</h2>
    <p class="mt-4 text-base leading-7 text-ink/74">{text(summary, locale)}</p>
    <p class="mt-4 text-sm leading-6 text-ink/64">{text(details, locale)}</p>
  </div>
</article>
