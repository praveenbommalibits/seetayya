---
import { formatDate, text } from "../lib/i18n";
import type { Locale } from "../data/site";

interface Localized {
  en: string;
  te?: string;
}

interface Props {
  date: Date;
  sponsorName: string;
  occasion: string;
  mealType: string;
  note: Localized;
  locale: Locale;
}

const { date, sponsorName, occasion, mealType, note, locale } = Astro.props;
const dateText = formatDate(date, locale);
---

<article class="rounded-lg border border-saffron-100 bg-white p-5 shadow-sm">
  <p class="text-sm font-bold uppercase tracking-wide text-saffron-700">
    <time datetime={date.toISOString()}>{dateText}</time>
  </p>
  <h3 class="mt-3 text-2xl font-extrabold text-ink">{sponsorName}</h3>
  <p class="mt-1 font-semibold text-leaf-700">{mealType} / {occasion}</p>
  <p class="mt-4 text-sm leading-6 text-ink/75">{text(note, locale)}</p>
</article>
