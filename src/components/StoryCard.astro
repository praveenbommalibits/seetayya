---
import { localizePath, text } from "../lib/i18n";
import { withBase } from "../lib/url";
import { ui, type Locale, type PartialLocalizedText } from "../data/site";

interface Props {
  slug: string;
  title: PartialLocalizedText;
  summary: PartialLocalizedText;
  category: PartialLocalizedText;
  image: string;
  locale: Locale;
}

const { slug, title, summary, category, image, locale } = Astro.props;
---

<article class="group overflow-hidden rounded-lg border border-ink/10 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
  <a href={localizePath(locale, `/impact/${slug}`)} class="block">
    <div class="aspect-[4/3] overflow-hidden bg-sand-100">
      <img src={withBase(image)} alt={text(title, locale)} loading="lazy" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
    </div>
    <div class="p-5">
      <p class="text-xs font-extrabold uppercase tracking-[0.18em] text-terracotta-700">{text(category, locale)}</p>
      <h3 class="mt-3 text-xl font-black leading-tight text-ink">{text(title, locale)}</h3>
      <p class="mt-3 line-clamp-3 text-sm leading-6 text-ink/70">{text(summary, locale)}</p>
      <span class="mt-4 inline-block text-sm font-extrabold text-leaf-700 underline">{text(ui.readStory, locale)}</span>
    </div>
  </a>
</article>
