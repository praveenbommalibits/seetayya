---
import { text } from "../lib/i18n";
import { withBase } from "../lib/url";
import type { Locale, PartialLocalizedText } from "../data/site";

interface Props {
  name: string;
  role?: string;
  image?: string;
  quote: PartialLocalizedText;
  locale: Locale;
}

const { name, role, image, quote, locale } = Astro.props;
const initials = name.split(" ").map((part) => part[0]).join("").slice(0, 2).toUpperCase();
---

<figure class="rounded-lg border border-ink/10 bg-white p-5 shadow-sm">
  <div class="flex items-center gap-3">
    {image ? (
      <img src={withBase(image)} alt={name} width="56" height="56" loading="lazy" class="h-14 w-14 rounded-full object-cover" />
    ) : (
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-saffron-50 text-sm font-black text-terracotta-700" aria-hidden="true">{initials}</div>
    )}
    <figcaption>
      <p class="text-sm font-extrabold text-ink">{name}</p>
      {role && <p class="text-xs font-bold uppercase tracking-wide text-leaf-700">{role}</p>}
    </figcaption>
  </div>
  <blockquote class="mt-4 text-sm leading-6 text-ink/74">"{text(quote, locale)}"</blockquote>
  {!image && (
    <p class="mt-4 rounded-md border border-dashed border-ink/15 bg-paper px-3 py-2 text-xs font-semibold text-ink/58">
      {locale === "te" ? "ఫోటోను founder తర్వాత జోడించవచ్చు." : "Photo slot ready for founder upload."}
    </p>
  )}
</figure>
