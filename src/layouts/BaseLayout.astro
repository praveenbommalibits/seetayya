---
import "../styles/global.css";
import { withBase } from "../lib/url";
import { contactInfo } from "../data/site";

interface Props {
  title: string;
  description: string;
  image?: string;
}

const {
  title,
  description,
  image = "/uploads/events/founders.jpg"
} = Astro.props;

const fallbackSite = "https://praveenbommalibits.github.io";
const canonical = new URL(withBase(Astro.url.pathname), Astro.site ?? fallbackSite);
const nav = [
  { href: "/about", label: "About" },
  { href: "/programs", label: "Programs" },
  { href: "/events", label: "Events" },
  { href: "/sponsor-a-day", label: "Sponsor a Day" },
  { href: "/media", label: "Media" },
  { href: "/donate", label: "Donate" },
  { href: "/contact", label: "Contact" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(withBase(image), Astro.site ?? fallbackSite)} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-4 focus:py-2 focus:font-bold">
      Skip to content
    </a>

    <header class="sticky top-0 z-40 border-b border-ink/10 bg-mist/95 backdrop-blur">
      <div class="container-pad flex min-h-20 items-center justify-between gap-4">
        <a href={withBase("/")} class="flex items-center gap-3" aria-label="Seetayya Foundation home">
          <img src={withBase("/uploads/logo.jpg")} alt="" class="h-12 w-12 rounded-full border border-leaf-700/15 object-cover" />
          <span class="leading-tight">
            <span class="block text-base font-extrabold text-ink">Seetayya Foundation</span>
            <span class="telugu block text-xs font-semibold text-leaf-700">సేవే మన ధర్మం</span>
          </span>
        </a>

        <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary navigation">
          {nav.map((item) => (
            <a href={withBase(item.href)} class="rounded-md px-3 py-2 text-sm font-bold text-ink/78 transition hover:bg-leaf-50 hover:text-leaf-700">
              {item.label}
            </a>
          ))}
        </nav>

        <div class="hidden items-center gap-3 lg:flex">
          <a href={withBase("/admin")} class="rounded-md border border-ink/15 px-3 py-2 text-sm font-bold text-ink/75 transition hover:border-leaf-700 hover:text-leaf-700">
            Admin
          </a>
          <a href={withBase("/donate")} class="rounded-md bg-leaf-700 px-4 py-2 text-sm font-extrabold text-white transition hover:bg-leaf-900">
            Donate
          </a>
        </div>

        <details class="relative lg:hidden">
          <summary class="list-none rounded-md border border-ink/15 px-3 py-2 text-sm font-bold text-ink">
            Menu
          </summary>
          <div class="absolute right-0 mt-3 w-64 rounded-lg border border-ink/10 bg-white p-3 shadow-soft">
            <nav class="grid gap-1" aria-label="Mobile navigation">
              {nav.map((item) => (
                <a href={withBase(item.href)} class="rounded-md px-3 py-2 text-sm font-bold text-ink/78 hover:bg-leaf-50">
                  {item.label}
                </a>
              ))}
              <a href={withBase("/admin")} class="rounded-md px-3 py-2 text-sm font-bold text-ink/78 hover:bg-leaf-50">Admin</a>
            </nav>
          </div>
        </details>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="border-t border-ink/10 bg-white">
      <div class="container-pad grid gap-10 py-12 md:grid-cols-[1.2fr_0.8fr_0.8fr]">
        <div>
          <div class="flex items-center gap-3">
            <img src={withBase("/uploads/logo.jpg")} alt="" class="h-12 w-12 rounded-full object-cover" />
            <div>
              <p class="font-extrabold">Seetayya Foundation</p>
              <p class="telugu text-sm text-leaf-700">అనాధలకు, వృద్ధులకు ఆశ్రయం</p>
            </div>
          </div>
          <p class="mt-4 max-w-md text-sm leading-6 text-ink/68">
            A nonprofit service home supporting elders, orphans, differently abled children, and people in need through food, shelter, medical care, and community events.
          </p>
        </div>
        <div>
          <h2 class="text-sm font-extrabold uppercase tracking-wide text-ink">Visit</h2>
          <p class="mt-3 text-sm leading-6 text-ink/68">
            {contactInfo.address.map((line) => <span>{line}<br /></span>)}
          </p>
          <p class="mt-3 text-sm leading-6 text-ink/68">
            {contactInfo.phones.join(" / ")}<br />
            {contactInfo.email}
          </p>
          <a href={withBase("/contact")} class="mt-3 inline-block text-sm font-bold text-leaf-700 underline">Contact the foundation</a>
        </div>
        <div>
          <h2 class="text-sm font-extrabold uppercase tracking-wide text-ink">Quick links</h2>
          <div class="mt-3 grid gap-2 text-sm font-semibold text-ink/68">
            <a href={withBase("/privacy-policy")} class="hover:text-leaf-700">Privacy Policy</a>
            <a href={withBase("/terms-condition")} class="hover:text-leaf-700">Terms & Condition</a>
            <a href={withBase("/refund-cancellation")} class="hover:text-leaf-700">Refund & Cancellation</a>
            <a href={withBase("/admin")} class="hover:text-leaf-700">Content Admin</a>
          </div>
        </div>
      </div>
      <div class="border-t border-ink/10 py-5">
        <div class="container-pad flex flex-col gap-2 text-xs font-semibold text-ink/55 sm:flex-row sm:items-center sm:justify-between">
          <p>© {new Date().getFullYear()} Seetayya Foundation. All rights reserved.</p>
          <p>Serving elders, orphans, differently abled children, and people in need.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
