---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { text } from "../../lib/i18n";
import { legalPages, locales, siteMeta, type Locale } from "../../data/site";

export function getStaticPaths() {
  return locales.flatMap((locale) =>
    Object.entries(legalPages).map(([legal, page]) => ({
      params: { locale, legal },
      props: { locale, page, legal }
    }))
  );
}

const { locale, page, legal } = Astro.props as {
  locale: Locale;
  legal: string;
  page: (typeof legalPages)[keyof typeof legalPages];
};
---

<BaseLayout title={`${text(page.title, locale)} | ${siteMeta.name}`} description={text(page.description, locale)} locale={locale} path={`/${locale}/${legal}`}>
  <section class="section-pad bg-white">
    <div class="container-pad max-w-3xl">
      <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">{locale === "te" ? "చట్టపరమైన సమాచారం" : "Legal"}</p>
      <h1 class="mt-3 text-5xl font-black text-ink">{text(page.title, locale)}</h1>
      <p class="mt-5 text-lg leading-8 text-ink/72">{text(page.description, locale)}</p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-pad max-w-3xl">
      <div class="rich-content rounded-lg border border-ink/10 bg-white p-6 text-lg leading-8 text-ink/74 shadow-sm">
        {page.sections.map((section) => (
          <section>
            <h2>{text(section.heading, locale)}</h2>
            {section.body[locale].map((paragraph) => <p>{paragraph}</p>)}
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
