---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CsrPartnerBlock from "../../components/CsrPartnerBlock.astro";
import TrustBadge from "../../components/TrustBadge.astro";
import { localizePath, text } from "../../lib/i18n";
import { withBase } from "../../lib/url";
import {
  contactInfo,
  csrProcess,
  csrSponsorshipTracks,
  locales,
  pageMeta,
  siteMeta,
  trustRegistry,
  volunteerTracks,
  type Locale
} from "../../data/site";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const subject = encodeURIComponent("CSR partnership enquiry - Seetayya Foundation");
---

<BaseLayout title={`${text(pageMeta.csr.title, locale)} | ${siteMeta.name}`} description={text(pageMeta.csr.description, locale)} locale={locale} path={`/${locale}/csr-partnerships`} image="/uploads/events/blood-camp.jpg">
  <section class="relative overflow-hidden bg-ink text-white">
    <img src={withBase("/uploads/events/blood-camp.jpg")} alt={locale === "te" ? "సీతయ్య ఫౌండేషన్ ఆరోగ్య శిబిరం" : "Seetayya Foundation health camp activity"} class="absolute inset-0 h-full w-full object-cover opacity-42" />
    <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/78 to-ink/35"></div>
    <div class="container-pad relative grid min-h-[34rem] items-end py-16">
      <div class="max-w-4xl" data-reveal>
        <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-saffron-100">{locale === "te" ? "కార్పొరేట్ భాగస్వామ్యం" : "Corporate partnerships"}</p>
        <h1 class="mt-4 text-5xl font-black leading-tight md:text-7xl">
          {locale === "te" ? "CSR నిధులు, ఉద్యోగుల సేవ, స్థిరమైన ప్రభావం." : "CSR funding, employee service, lasting local impact."}
        </h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-white/82">{text(pageMeta.csr.description, locale)}</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={`mailto:${contactInfo.email}?subject=${subject}`} class="inline-flex items-center justify-center rounded-md bg-saffron-500 px-6 py-3 text-sm font-extrabold text-ink transition hover:bg-saffron-100">
            {locale === "te" ? "CSR గురించి సంప్రదించండి" : "Talk to us about CSR"}
          </a>
          <a href={localizePath(locale, "/volunteer")} class="inline-flex items-center justify-center rounded-md border border-white/40 px-6 py-3 text-sm font-extrabold text-white transition hover:bg-white/10">
            {locale === "te" ? "ఉద్యోగుల స్వచ్ఛంద సేవ" : "Employee volunteering"}
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="container-pad grid gap-6 md:grid-cols-2 lg:grid-cols-4" data-reveal>
      <TrustBadge label={text(trustRegistry.registration.label, locale)} value={text(trustRegistry.registration.value, locale)} />
      <TrustBadge label={text(trustRegistry.csr.label, locale)} value={text(trustRegistry.csr.value, locale)} tone="gold" />
      <TrustBadge label={text(trustRegistry.ngoDarpan.label, locale)} value={text(trustRegistry.ngoDarpan.value, locale)} tone="indigo" />
      <TrustBadge label={text(trustRegistry.fcra.label, locale)} value={text(trustRegistry.fcra.value, locale)} tone="terracotta" />
    </div>
  </section>

  <section class="section-pad">
    <div class="container-pad" data-reveal>
      <div class="max-w-3xl">
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">{locale === "te" ? "భాగస్వామ్య మార్గాలు" : "Ways to partner"}</p>
        <h2 class="mt-3 text-4xl font-black leading-tight text-ink">{locale === "te" ? "మీ కంపెనీ సహాయం చేయగల స్పష్టమైన మార్గాలు." : "Clear ways your company can support the home."}</h2>
        <p class="mt-4 text-lg leading-8 text-ink/72">
          {locale === "te"
            ? "CRY మరియు Team Everest వంటి CSR పేజీల pattern ప్రకారం, ఇక్కడ funding, in-kind support, employee engagement, payroll giving అన్నీ వేర్వేరుగా స్పష్టంగా చూపించాం."
            : "The structure separates project funding, in-kind support, employee engagement, and payroll giving so companies can choose the right fit quickly."}
        </p>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        {csrSponsorshipTracks.map((track) => (
          <article class="rounded-lg border border-ink/10 bg-white p-6 shadow-sm">
            <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-terracotta-700">{text(track.eyebrow, locale)}</p>
            <h3 class="mt-3 text-2xl font-black leading-tight text-ink">{text(track.title, locale)}</h3>
            <p class="mt-4 text-sm leading-6 text-ink/70">{text(track.text, locale)}</p>
            <ul class="mt-5 grid gap-2 text-sm font-bold text-ink/72">
              {track.items.map((item) => (
                <li class="flex gap-2"><span class="mt-2 h-2 w-2 rounded-full bg-leaf-700" aria-hidden="true"></span>{text(item, locale)}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="container-pad grid gap-8 lg:grid-cols-[0.8fr_1.2fr]" data-reveal>
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-terracotta-700">{locale === "te" ? "ఉద్యోగుల సేవ" : "Employee volunteering"}</p>
        <h2 class="mt-3 text-4xl font-black leading-tight text-ink">{locale === "te" ? "రోజువారీ ఉద్యోగంతో పాటు చేయగల సేవ." : "Volunteering that can fit around regular work."}</h2>
        <p class="mt-4 text-lg leading-8 text-ink/72">
          {locale === "te"
            ? "ఉద్యోగులు onsite, remote, weekend, half-day లేదా monthly basis లో పాల్గొనవచ్చు. Foundation role ను ముందుగానే define చేస్తుంది."
            : "Employees can join on-site, remotely, on weekends, for a half-day, or monthly. The foundation defines a useful role before they arrive."}
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {volunteerTracks.slice(0, 4).map((track) => (
          <article class="rounded-lg border border-ink/10 bg-paper p-5">
            <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-leaf-700">{text(track.commitment, locale)}</p>
            <h3 class="mt-3 text-xl font-black text-ink">{text(track.title, locale)}</h3>
            <p class="mt-3 text-sm leading-6 text-ink/70">{text(track.text, locale)}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-pad" data-reveal>
      <div class="max-w-3xl">
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">{locale === "te" ? "ఎలా పని చేస్తుంది" : "How it works"}</p>
        <h2 class="mt-3 text-4xl font-black text-ink">{locale === "te" ? "స్పష్టమైన ప్రక్రియ, స్పష్టమైన నివేదికలు." : "A clear process, then clear reporting."}</h2>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-4">
        {csrProcess.map((step, index) => (
          <article class="rounded-lg border border-ink/10 bg-white p-5 shadow-sm">
            <p class="text-3xl font-black text-saffron-700">{String(index + 1).padStart(2, "0")}</p>
            <h3 class="mt-4 text-xl font-black text-ink">{text(step.title, locale)}</h3>
            <p class="mt-3 text-sm leading-6 text-ink/70">{text(step.text, locale)}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="container-pad grid gap-8 lg:grid-cols-[0.9fr_1.1fr]" data-reveal>
      <CsrPartnerBlock locale={locale} />
      <form action={`mailto:${contactInfo.email}?subject=${subject}`} method="post" enctype="text/plain" class="paper-panel rounded-lg p-6">
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">{locale === "te" ? "CSR ఆసక్తి ఫారం" : "CSR interest form"}</p>
        <h2 class="mt-3 text-3xl font-black text-ink">{locale === "te" ? "మీ కంపెనీ సహాయం ఎలా చేయాలనుకుంటుంది?" : "How would your company like to help?"}</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <label class="grid gap-2 text-sm font-bold text-ink">
            {locale === "te" ? "కంపెనీ పేరు" : "Company name"}
            <input name="Company" required class="rounded-md border border-ink/15 px-3 py-3 font-normal" />
          </label>
          <label class="grid gap-2 text-sm font-bold text-ink">
            {locale === "te" ? "సంప్రదించే వ్యక్తి" : "Contact person"}
            <input name="Contact person" required class="rounded-md border border-ink/15 px-3 py-3 font-normal" />
          </label>
          <label class="grid gap-2 text-sm font-bold text-ink">
            {locale === "te" ? "ఇమెయిల్ / ఫోన్" : "Email / phone"}
            <input name="Email or phone" required class="rounded-md border border-ink/15 px-3 py-3 font-normal" />
          </label>
          <label class="grid gap-2 text-sm font-bold text-ink">
            {locale === "te" ? "ఆసక్తి" : "Interest"}
            <select name="CSR interest" class="rounded-md border border-ink/15 px-3 py-3 font-normal">
              <option>Project sponsorship</option>
              <option>Employee volunteering</option>
              <option>In-kind donation</option>
              <option>Payroll / matched giving</option>
            </select>
          </label>
          <label class="grid gap-2 text-sm font-bold text-ink md:col-span-2">
            {locale === "te" ? "సందేశం" : "Message"}
            <textarea name="Message" rows="5" class="rounded-md border border-ink/15 px-3 py-3 font-normal"></textarea>
          </label>
        </div>
        <label class="mt-5 flex gap-3 text-sm leading-6 text-ink/72">
          <input type="checkbox" required class="mt-1" />
          <span>{locale === "te" ? "ఈ CSR enquiry కు స్పందించడానికి ఫౌండేషన్ ఈ వివరాలను ఉపయోగించవచ్చని అంగీకరిస్తున్నాను." : "I consent to the foundation using these details to respond to this CSR enquiry."}</span>
        </label>
        <button class="mt-6 rounded-md bg-leaf-700 px-5 py-3 text-sm font-extrabold text-white transition hover:bg-leaf-900">
          {locale === "te" ? "ఇమెయిల్ ద్వారా పంపండి" : "Send by email"}
        </button>
        <p class="mt-4 text-xs leading-5 text-ink/55">{locale === "te" ? "ఈ static form visitor email client ను తెరుస్తుంది." : "This static form opens the visitor's email client."}</p>
      </form>
    </div>
  </section>
</BaseLayout>
