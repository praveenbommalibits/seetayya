---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ImpactTier from "../../components/ImpactTier.astro";
import TrustBadge from "../../components/TrustBadge.astro";
import { text } from "../../lib/i18n";
import { withBase } from "../../lib/url";
import {
  contactInfo,
  impactTiers,
  locales,
  pageMeta,
  siteMeta,
  transparencyNotes,
  type Locale
} from "../../data/site";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const donation = await getEntry("donationSettings", "main");
const paymentUrl = donation?.data.razorpayPaymentLink ?? "https://seetayyafoundation.org/give/donation/";
const hasConfiguredPayment = Boolean(donation?.data.razorpayPaymentLink);
---

<BaseLayout title={`${text(pageMeta.donate.title, locale)} | ${siteMeta.name}`} description={text(pageMeta.donate.description, locale)} locale={locale} path={`/${locale}/donate`} image="/uploads/events/donate-us-photo.jpg">
  <section class="section-pad bg-white">
    <div class="container-pad grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-saffron-700">{text(pageMeta.donate.title, locale)}</p>
        <h1 class="mt-3 text-5xl font-black leading-tight text-ink">
          {locale === "te" ? "మీ దానం నేరుగా నిత్య సంరక్షణకు తోడ్పడుతుంది." : "Your donation supports daily care directly."}
        </h1>
        <p class="mt-6 text-lg leading-8 text-ink/72">
          {locale === "te"
            ? "ఆహారం, ఆశ్రయం, ఔషధాలు, పునరావాస సేవలకు impact-tied donation ఎంపికను ఎంచుకోండి."
            : "Choose an impact-tied amount for food, shelter, medicines, and rehabilitation-oriented service."}
        </p>
      </div>
      <img src={withBase("/uploads/events/donate-us-photo.jpg")} alt={locale === "te" ? "సీతయ్య ఫౌండేషన్ దానం చిత్రం" : "Donation support for Seetayya Foundation"} class="rounded-lg object-cover shadow-soft" />
    </div>
  </section>

  <section class="section-pad">
    <div class="container-pad grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <form id="donation-form" class="paper-panel rounded-lg p-6">
        <div class="flex rounded-lg border border-ink/10 bg-white p-1" role="group" aria-label={locale === "te" ? "దానం విధానం" : "Donation frequency"}>
          <label class="flex-1 cursor-pointer rounded-md px-3 py-2 text-center text-sm font-extrabold has-[:checked]:bg-leaf-700 has-[:checked]:text-white">
            <input class="sr-only" type="radio" name="frequency" value="once" checked />
            {locale === "te" ? "ఒకసారి" : "One-time"}
          </label>
          <label class="flex-1 cursor-pointer rounded-md px-3 py-2 text-center text-sm font-extrabold has-[:checked]:bg-leaf-700 has-[:checked]:text-white">
            <input class="sr-only" type="radio" name="frequency" value="monthly" />
            {locale === "te" ? "నెలవారీ" : "Monthly"}
          </label>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {impactTiers.map((tier) => <ImpactTier {...tier} locale={locale} />)}
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <label class="grid gap-2 text-sm font-bold text-ink">
            {locale === "te" ? "కస్టమ్ మొత్తం" : "Custom amount"}
            <input id="donation-amount" name="amount" inputmode="numeric" value="5000" class="rounded-md border border-ink/15 bg-white px-3 py-3 font-normal" />
          </label>
          <label class="grid gap-2 text-sm font-bold text-ink">
            {locale === "te" ? "ఇమెయిల్" : "Email"}
            <input id="donor-email" name="email" type="email" required class="rounded-md border border-ink/15 bg-white px-3 py-3 font-normal" />
          </label>
          <label class="grid gap-2 text-sm font-bold text-ink">
            {locale === "te" ? "పేరు (ఐచ్చికం)" : "Name (optional)"}
            <input name="name" class="rounded-md border border-ink/15 bg-white px-3 py-3 font-normal" />
          </label>
          <label class="grid gap-2 text-sm font-bold text-ink">
            {locale === "te" ? "ఫోన్ (ఐచ్చికం)" : "Phone (optional)"}
            <input name="phone" class="rounded-md border border-ink/15 bg-white px-3 py-3 font-normal" />
          </label>
        </div>

        <fieldset class="mt-6 rounded-lg border border-ink/10 bg-white p-4">
          <legend class="px-1 text-sm font-extrabold text-ink">{locale === "te" ? "దాత మూలం" : "Donor source"}</legend>
          <div class="mt-3 grid gap-3 sm:grid-cols-2">
            <label class="flex gap-3 text-sm font-semibold text-ink/72">
              <input type="radio" name="donorSource" value="india" checked />
              {locale === "te" ? "భారతీయ మూలం" : "Indian source"}
            </label>
            <label class="flex gap-3 text-sm font-semibold text-ink/72">
              <input type="radio" name="donorSource" value="foreign" />
              {locale === "te" ? "విదేశీ / NRI" : "Foreign / NRI"}
            </label>
          </div>
          <p id="fcra-notice" class="mt-3 hidden rounded-md border border-terracotta-500/25 bg-terracotta-50 p-3 text-sm leading-6 text-terracotta-700">
            {text(transparencyNotes.fcra, locale)}
          </p>
        </fieldset>

        <label class="mt-6 flex gap-3 text-sm leading-6 text-ink/72">
          <input id="donor-consent" type="checkbox" required class="mt-1" />
          <span>
            {locale === "te"
              ? "నా వివరాలను donation receipt, contact follow-up, చట్టపరమైన records కోసం ఫౌండేషన్ ఉపయోగించవచ్చని అంగీకరిస్తున్నాను."
              : "I consent to the foundation using my details for donation receipt, contact follow-up, and legally required records."}
          </span>
        </label>

        <p id="donation-error" class="mt-4 hidden rounded-md border border-terracotta-500/25 bg-terracotta-50 p-3 text-sm font-semibold text-terracotta-700"></p>

        <button id="donate-submit" class="mt-6 w-full rounded-md bg-leaf-700 px-5 py-3 text-sm font-extrabold text-white transition hover:bg-leaf-900">
          {locale === "te" ? "సురక్షిత చెల్లింపుకు వెళ్లండి" : "Continue to secure payment"}
        </button>

        <p class="mt-4 text-xs leading-5 text-ink/55">
          {hasConfiguredPayment
            ? locale === "te" ? "Razorpay hosted payment link configuration నుంచి తెరుచుకుంటుంది." : "The configured Razorpay hosted payment link opens after validation."
            : locale === "te" ? "ప్రస్తుతానికి పాత వెబ్‌సైట్‌లోని ధృవీకరించిన Razorpay/GiveWP donation form fallback గా తెరుచుకుంటుంది." : "Until a new Razorpay Payment Page link is added, this opens the verified existing Razorpay/GiveWP donation form from the old site."}
        </p>
      </form>

      <aside class="grid content-start gap-4">
        <TrustBadge label={locale === "te" ? "సురక్షిత చెల్లింపు" : "Secure payment"} value={locale === "te" ? "Hosted Razorpay / UPI ప్రాధాన్యం" : "Hosted Razorpay / UPI first"} />
        <TrustBadge label={locale === "te" ? "చట్టపరమైన పేరు" : "Legal name"} value={siteMeta.legalName} tone="gold" />
        <TrustBadge label={locale === "te" ? "నమోదు" : "Registration"} value={siteMeta.registrationNumber} tone="indigo" />
        <TrustBadge label="80G" value="AAYTS9135NF20217" tone="terracotta" />
        <div class="rounded-lg border border-ink/10 bg-white p-5 text-sm leading-6 text-ink/70">
          <p class="font-extrabold text-ink">{locale === "te" ? "రసీదు గమనిక" : "Receipt note"}</p>
          <p class="mt-2">{text(donation?.data.receiptNote ?? { en: "", te: "" }, locale)}</p>
          <p class="mt-3 font-bold">{contactInfo.email}<br />{contactInfo.phones.join(" / ")}</p>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline define:vars={{ paymentUrl, locale }}>
    const form = document.getElementById("donation-form");
    const amountInput = document.getElementById("donation-amount");
    const errorBox = document.getElementById("donation-error");
    const fcraNotice = document.getElementById("fcra-notice");
    const submitButton = document.getElementById("donate-submit");

    document.querySelectorAll(".donation-tier").forEach((button) => {
      button.addEventListener("click", () => {
        amountInput.value = button.getAttribute("data-amount") || "5000";
      });
    });

    form.querySelectorAll('input[name="donorSource"]').forEach((radio) => {
      radio.addEventListener("change", () => {
        const foreign = form.querySelector('input[name="donorSource"]:checked')?.value === "foreign";
        fcraNotice.classList.toggle("hidden", !foreign);
        submitButton.disabled = foreign;
        submitButton.classList.toggle("opacity-50", foreign);
      });
    });

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      errorBox.classList.add("hidden");
      errorBox.textContent = "";
      const foreign = form.querySelector('input[name="donorSource"]:checked')?.value === "foreign";
      const consent = document.getElementById("donor-consent").checked;
      const email = document.getElementById("donor-email").value.trim();
      const amount = Number(amountInput.value);

      if (foreign) {
        errorBox.textContent = locale === "te" ? "FCRA ధృవీకరణ వచ్చే వరకు foreign/NRI donations స్వీకరించలేం." : "Foreign/NRI donations cannot be accepted until FCRA details are confirmed.";
      } else if (!email || !consent || !amount || amount < 1) {
        errorBox.textContent = locale === "te" ? "దయచేసి మొత్తం, ఇమెయిల్, consent పూర్తి చేయండి." : "Please complete amount, email, and consent before continuing.";
      }

      if (errorBox.textContent) {
        errorBox.classList.remove("hidden");
        return;
      }

      window.location.href = paymentUrl;
    });
  </script>
</BaseLayout>
