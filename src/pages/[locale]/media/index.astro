---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { localizePath, text } from "../../../lib/i18n";
import { withBase } from "../../../lib/url";
import { categoryLabels, locales, pageMeta, siteMeta, videos, type Locale } from "../../../data/site";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const albums = (await getCollection("albums"))
  .filter((entry) => entry.data.published)
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
---

<BaseLayout title={`${text(pageMeta.media.title, locale)} | ${siteMeta.name}`} description={text(pageMeta.media.description, locale)} locale={locale} path={`/${locale}/media`}>
  <section class="section-pad bg-white">
    <div class="container-pad">
      <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">{text(pageMeta.media.title, locale)}</p>
      <h1 class="mt-3 max-w-4xl text-5xl font-black leading-tight text-ink">{locale === "te" ? "ఫౌండేషన్ నిజమైన సేవా చిత్రాలు." : "Authentic foundation photos, not stock imagery."}</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-ink/72">{text(pageMeta.media.description, locale)}</p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-pad grid gap-6 md:grid-cols-2">
      {albums.map((album) => (
        <a href={localizePath(locale, `/media/${album.slug}`)} class="group overflow-hidden rounded-lg border border-ink/10 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
          <div class="aspect-[16/10] overflow-hidden bg-leaf-50">
            <img src={withBase(album.data.coverImage)} alt={text(album.data.title, locale)} loading="lazy" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
          </div>
          <div class="p-6">
            <p class="text-sm font-extrabold uppercase tracking-wide text-leaf-700">{text(categoryLabels[album.data.category] ?? { en: album.data.category, te: album.data.category }, locale)}</p>
            <h2 class="mt-2 text-2xl font-black text-ink">{text(album.data.title, locale)}</h2>
            <p class="mt-4 text-sm leading-6 text-ink/70">{text(album.data.summary, locale)}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  {videos.length > 0 && (
    <section class="section-pad bg-white">
      <div class="container-pad">
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-terracotta-700">{locale === "te" ? "వీడియోలు" : "Videos"}</p>
        <h2 class="mt-3 text-4xl font-black text-ink">{locale === "te" ? "సేవా కార్యక్రమాల వీడియోలు" : "Videos from foundation activities"}</h2>
        <p class="mt-4 max-w-3xl text-sm leading-6 text-ink/65">
          {locale === "te"
            ? "పాత వెబ్‌సైట్ నుండి మార్చిన YouTube వీడియోలు. వీడియో play చేసినప్పుడు మాత్రమే YouTube load అవుతుంది."
            : "YouTube videos migrated from the old website. YouTube loads only when a video is played."}
        </p>
        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {videos.map((video) => (
            <button
              type="button"
              class="video-embed group relative aspect-video overflow-hidden rounded-lg border border-ink/10 bg-ink shadow-sm"
              data-video-id={video.id}
              aria-label={locale === "te" ? "వీడియో ప్లే చేయండి" : "Play video"}
            >
              <img
                src={`https://i.ytimg.com/vi/${video.id}/hqdefault.jpg`}
                alt=""
                loading="lazy"
                class="h-full w-full object-cover opacity-85 transition duration-500 group-hover:scale-105 group-hover:opacity-100"
              />
              <span class="absolute inset-0 grid place-items-center">
                <span class="grid h-14 w-14 place-items-center rounded-full bg-terracotta-700/95 text-white shadow-soft transition group-hover:scale-110">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5.14v13.72L19 12 8 5.14z"/></svg>
                </span>
              </span>
            </button>
          ))}
        </div>
      </div>
    </section>
  )}

  <script>
    document.querySelectorAll<HTMLButtonElement>(".video-embed").forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.dataset.videoId;
        if (!id) return;
        const iframe = document.createElement("iframe");
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
        iframe.title = "Seetayya Foundation video";
        iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
        iframe.allowFullscreen = true;
        iframe.className = "absolute inset-0 h-full w-full";
        button.replaceChildren(iframe);
      });
    });
  </script>
</BaseLayout>
