---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CtaBand from "../../components/CtaBand.astro";
import ProgramCard from "../../components/ProgramCard.astro";
import { text } from "../../lib/i18n";
import { locales, pageMeta, programs, serviceAreas, siteMeta, type Locale } from "../../data/site";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
---

<BaseLayout title={`${text(pageMeta.programs.title, locale)} | ${siteMeta.name}`} description={text(pageMeta.programs.description, locale)} locale={locale} path={`/${locale}/programs`} image="/uploads/events/residents-care.jpg">
  <section class="section-pad bg-white">
    <div class="container-pad">
      <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">{locale === "te" ? "సేవా కార్యక్రమాలు" : "Programs"}</p>
      <h1 class="mt-3 max-w-4xl text-5xl font-black leading-tight text-ink">{locale === "te" ? "ఆశ్రయం నుంచి ఆరోగ్య శిబిరాల వరకు, సేవ ఒకే దారిలో సాగుతోంది." : "From shelter to health camps, every programme follows the same service promise."}</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-ink/72">{text(pageMeta.programs.description, locale)}</p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-pad grid gap-6">
      {programs.map((program) => <ProgramCard {...program} locale={locale} />)}
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="container-pad">
      <div class="max-w-3xl">
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-terracotta-700">{locale === "te" ? "అదనపు సేవా ప్రాంతాలు" : "Additional service areas"}</p>
        <h2 class="mt-3 text-4xl font-black text-ink">{locale === "te" ? "పాత సైట్‌లో ఉన్న సేవా అంశాలు" : "Service areas carried from the old site"}</h2>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {serviceAreas.map((area) => (
          <article class="rounded-lg border border-ink/10 bg-paper p-6">
            <h3 class="text-xl font-black text-ink">{text(area.title, locale)}</h3>
            <p class="mt-3 text-sm leading-6 text-ink/70">{text(area.text, locale)}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    locale={locale}
    eyebrow={{ en: "Help the work continue", te: "సేవ కొనసాగేందుకు తోడ్పాటు" }}
    title={{ en: "Support daily food, shelter, and future rehabilitation care.", te: "నిత్య ఆహారం, ఆశ్రయం, భవిష్యత్ పునరావాస సేవకు సహాయం చేయండి." }}
    body={{ en: "Choose an impact tier or sponsor a full day of care for the people staying at the foundation.", te: "ప్రభావంతో అనుసంధానించిన దానం ఎంపికను ఎంచుకోండి లేదా ఒక పూర్తి రోజు సేవను స్పాన్సర్ చేయండి." }}
  />
</BaseLayout>
