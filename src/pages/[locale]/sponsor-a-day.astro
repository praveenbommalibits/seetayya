---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ImpactTier from "../../components/ImpactTier.astro";
import SponsorCard from "../../components/SponsorCard.astro";
import { localizePath, text } from "../../lib/i18n";
import { withBase } from "../../lib/url";
import { impactTiers, locales, pageMeta, siteMeta, type Locale } from "../../data/site";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const sponsors = (await getCollection("dailySponsors"))
  .filter((entry) => entry.data.published)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={`${text(pageMeta.sponsor.title, locale)} | ${siteMeta.name}`} description={text(pageMeta.sponsor.description, locale)} locale={locale} path={`/${locale}/sponsor-a-day`} image="/uploads/events/residents-care.jpg">
  <section class="section-pad bg-white">
    <div class="container-pad grid gap-10 lg:grid-cols-[1fr_0.85fr] lg:items-center">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-saffron-700">{text(pageMeta.sponsor.title, locale)}</p>
        <h1 class="mt-3 text-5xl font-black leading-tight text-ink">
          {locale === "te" ? "ఒక రోజు ఆహారం, ఔషధాలు, గౌరవప్రద సంరక్షణ." : "One day of meals, medicines, and dignified care."}
        </h1>
        <p class="mt-6 text-lg leading-8 text-ink/72">
          {locale === "te"
            ? "నిత్యాన్నదాన నిలయం ఫౌండేషన్ సేవలో ముఖ్యమైన భాగం. మీ స్పాన్సర్‌షిప్ వృద్ధాశ్రమ నివాసుల రోజువారీ సంరక్షణకు నేరుగా తోడ్పడుతుంది."
            : "Nityannadana Nilayam is central to the foundation's service. A sponsor-day gift directly supports daily care for residents at the home."}
        </p>
        <a href={localizePath(locale, "/donate")} class="mt-7 inline-flex rounded-md bg-leaf-700 px-6 py-3 text-sm font-extrabold text-white transition hover:bg-leaf-900">
          {locale === "te" ? "ఒక రోజు స్పాన్సర్ చేయండి" : "Sponsor a day"}
        </a>
      </div>
      <img src={withBase("/uploads/events/residents-care.jpg")} alt={locale === "te" ? "సీతయ్య ఫౌండేషన్‌లో నిత్య సంరక్షణ" : "Daily care at Seetayya Foundation"} class="rounded-lg object-cover shadow-soft" />
    </div>
  </section>

  <section class="section-pad">
    <div class="container-pad">
      <div class="max-w-3xl">
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-terracotta-700">{locale === "te" ? "ప్రభావం" : "Impact tiers"}</p>
        <h2 class="mt-3 text-4xl font-black text-ink">{locale === "te" ? "దాతలు సులభంగా ఎంచుకునే సహాయం" : "Simple giving options for daily care"}</h2>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-4">
        {impactTiers.map((tier) => <ImpactTier {...tier} locale={locale} />)}
      </div>
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="container-pad">
      <h2 class="text-3xl font-black text-ink">{locale === "te" ? "ఇటీవలి sponsor-day entries" : "Recent sponsor-day entries"}</h2>
      {sponsors.length > 0 ? (
        <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {sponsors.map((sponsor) => <SponsorCard {...sponsor.data} locale={locale} />)}
        </div>
      ) : (
        <div class="mt-8 rounded-lg border border-ink/10 bg-paper p-6 text-sm leading-6 text-ink/70 shadow-sm">
          {locale === "te"
            ? "ధృవీకరించిన public sponsor-day entries ప్రస్తుతం లేవు. sponsor పేరు, తేదీ, meal type, photo permission ఫౌండేషన్ ధృవీకరించిన తర్వాత ఇవి ఇక్కడ ప్రచురించవచ్చు."
            : "No verified public sponsor-day entries are currently published. The foundation can add entries after confirming sponsor name, date, meal type, and permission to display photos."}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
