---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CertificateCard from "../../components/CertificateCard.astro";
import CsrPartnerBlock from "../../components/CsrPartnerBlock.astro";
import TrustBadge from "../../components/TrustBadge.astro";
import { text } from "../../lib/i18n";
import { locales, pageMeta, siteMeta, transparencyNotes, trustRegistry, type Locale } from "../../data/site";

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const certificates = (await getCollection("certificates"))
  .filter((entry) => entry.data.published)
  .sort((a, b) => a.data.order - b.data.order || text(a.data.title, locale).localeCompare(text(b.data.title, locale)));
---

<BaseLayout title={`${text(pageMeta.transparency.title, locale)} | ${siteMeta.name}`} description={text(pageMeta.transparency.description, locale)} locale={locale} path={`/${locale}/transparency`}>
  <section class="section-pad bg-white">
    <div class="container-pad">
      <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">{text(pageMeta.transparency.title, locale)}</p>
      <h1 class="mt-3 max-w-4xl text-5xl font-black leading-tight text-ink">{locale === "te" ? "నమ్మకం స్పష్టమైన సమాచారంతో మొదలవుతుంది." : "Trust starts with clear public information."}</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-ink/72">{text(pageMeta.transparency.description, locale)}</p>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-pad grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      <TrustBadge label={locale === "te" ? "నమోదు" : "Registration"} value={siteMeta.registrationNumber} />
      <TrustBadge label="12A / 12AB" value="AAYTS9135NE20219" tone="gold" />
      <TrustBadge label="80G" value="AAYTS9135NF20217" tone="terracotta" />
      <TrustBadge label="FCRA" value={locale === "te" ? "విదేశీ దానం నిలిపివేత" : "Foreign donation gated"} tone="indigo" />
      <TrustBadge label={text(trustRegistry.csr.label, locale)} value={text(trustRegistry.csr.value, locale)} tone="green" />
      <TrustBadge label={text(trustRegistry.ngoDarpan.label, locale)} value={text(trustRegistry.ngoDarpan.value, locale)} tone="indigo" />
      <TrustBadge label={text(trustRegistry.pan.label, locale)} value={text(trustRegistry.pan.value, locale)} tone="gold" />
      <TrustBadge label={text(trustRegistry.fcra.label, locale)} value={text(trustRegistry.fcra.value, locale)} tone="terracotta" />
    </div>
    <div class="container-pad mt-8 grid gap-4 lg:grid-cols-2">
      {Object.entries(transparencyNotes).map(([key, note]) => (
        <article class="rounded-lg border border-ink/10 bg-white p-5 shadow-sm">
          <h2 class="text-sm font-extrabold uppercase tracking-[0.16em] text-leaf-700">{key}</h2>
          <p class="mt-3 text-sm leading-6 text-ink/72">{text(note, locale)}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="container-pad">
      <h2 class="text-4xl font-black text-ink">{locale === "te" ? "పత్రాలు" : "Documents"}</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {certificates.map((certificate) => (
          <CertificateCard
            id={certificate.slug}
            title={certificate.data.title}
            issuer={certificate.data.issuer}
            image={certificate.data.image}
            file={certificate.data.file}
            status={certificate.data.status}
            publicNumber={certificate.data.publicNumber}
            locale={locale}
          />
        ))}
        <article class="rounded-lg border border-dashed border-ink/20 bg-paper p-6">
          <h3 class="text-xl font-black text-ink">{locale === "te" ? "ఆడిట్ నివేదిక / వార్షిక నివేదిక" : "Audited financials / Annual report"}</h3>
          <p class="mt-3 text-sm leading-6 text-ink/70">
            {locale === "te" ? "ఫౌండేషన్ public PDF అప్‌లోడ్ చేసిన తర్వాత ఈ స్థానంలో లింక్ కనిపిస్తుంది." : "Placeholder slot for public PDFs after the foundation uploads final reports."}
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-pad grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">{locale === "te" ? "కార్పొరేట్ భాగస్వామ్యం" : "Corporate giving"}</p>
        <h2 class="mt-3 text-4xl font-black leading-tight text-ink">{locale === "te" ? "CSR సహాయానికి స్పష్టమైన మార్గం." : "A clear path for CSR support."}</h2>
        <p class="mt-4 text-lg leading-8 text-ink/72">
          {locale === "te"
            ? "కంపెనీలు భోజనం, వృద్ధ సంరక్షణ, ఆరోగ్య శిబిరాలు, పునరావాస కేంద్రానికి సహాయం చేయగలవు. నమోదు సంఖ్య ధృవీకరించగానే ఇక్కడ నవీకరించబడుతుంది."
            : "Companies can support meals, elder care, health camps, and the rehabilitation center. The registration number will be updated here as soon as the founder confirms it."}
        </p>
      </div>
      <CsrPartnerBlock locale={locale} />
    </div>
  </section>
</BaseLayout>
