---
import { getEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBase } from "../lib/url";

const page = await getEntry("pages", "about");
const { Content } = await page!.render();
---

<BaseLayout title="About | Seetayya Foundation" description={page!.data.description.en} image={page!.data.heroImage}>
  <section class="bg-white">
    <div class="container-pad grid gap-10 py-16 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">About us</p>
        <h1 class="mt-3 text-5xl font-black leading-tight text-ink">{page!.data.title.en}</h1>
        <p class="telugu mt-4 text-lg font-semibold text-leaf-700">{page!.data.title.te}</p>
        <div class="rich-content mt-6 text-lg leading-8 text-ink/72">
          <Content />
        </div>
      </div>
      <img src={withBase(page!.data.heroImage)} alt="Seetayya Foundation founders and service story" class="rounded-lg object-cover shadow-soft" />
    </div>
  </section>
  <section class="py-16">
    <div class="container-pad grid gap-5 md:grid-cols-3">
      {[
        ["Care", "Daily food, shelter, and emotional support for vulnerable people."],
        ["Dignity", "Respectful language, responsible media, and consent-first public stories."],
        ["Transparency", "Certificates, sponsor updates, and events are visible to the community."]
      ].map(([title, text]) => (
        <div class="rounded-lg border border-ink/10 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-extrabold text-ink">{title}</h2>
          <p class="mt-3 text-sm leading-6 text-ink/70">{text}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
