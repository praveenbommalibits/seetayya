---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBase } from "../lib/url";

const certificateOrder = [
  "registration",
  "service-recognition",
  "form-10ac-12a",
  "form-10ac-80g",
  "csr-certificate"
];

const certificates = (await getCollection("certificates"))
  .filter((entry) => entry.data.published)
  .sort((a, b) => certificateOrder.indexOf(a.slug) - certificateOrder.indexOf(b.slug));

const certificatesWithContent = await Promise.all(
  certificates.map(async (certificate) => {
    const { Content } = await certificate.render();
    return { certificate, Content };
  })
);
---

<BaseLayout title="Certificates | Seetayya Foundation" description="Foundation registration documents, recognitions, and certificates for Seetayya Foundation.">
  <section class="bg-white py-16">
    <div class="container-pad">
      <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">Certificates</p>
      <h1 class="mt-3 max-w-3xl text-5xl font-black leading-tight text-ink">Trust documents and recognitions.</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-ink/72">The old website lists the foundation registration certificate, 12AA, 12A, 80G, Form 10AC, and CSR-related certificate information.</p>
    </div>
  </section>
  <section class="py-16">
    <div class="container-pad grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {certificatesWithContent.map(({ certificate, Content }) => (
        <article class="rounded-lg border border-ink/10 bg-white p-4 shadow-sm">
          {certificate.data.image && (
            <a href={withBase(certificate.data.file ?? certificate.data.image)} class="block rounded-md border border-ink/10 bg-mist p-3 transition hover:border-leaf-700">
              <img src={withBase(certificate.data.image)} alt={certificate.data.title.en} class="mx-auto aspect-[3/4] max-h-[28rem] w-full rounded-sm object-contain" loading="lazy" />
            </a>
          )}
          <h2 class="mt-5 text-xl font-black text-ink">{certificate.data.title.en}</h2>
          {certificate.data.title.te && <p class="telugu mt-2 font-semibold text-leaf-700">{certificate.data.title.te}</p>}
          <p class="mt-3 text-sm text-ink/70">{certificate.data.issuer}</p>
          <div class="rich-content mt-4 text-sm leading-6 text-ink/70">
            <Content />
          </div>
          {certificate.data.file && (
            <a href={withBase(certificate.data.file)} class="mt-4 inline-flex rounded-md border border-leaf-700 px-4 py-2 text-sm font-extrabold text-leaf-700 hover:bg-leaf-50">Open full scan</a>
          )}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
