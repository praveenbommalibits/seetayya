---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

const certificates = (await getCollection("certificates"))
  .filter((entry) => entry.data.published)
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
---

<BaseLayout title="Certificates | Seetayya Foundation" description="Foundation registration documents, recognitions, and certificates for Seetayya Foundation.">
  <section class="bg-white py-16">
    <div class="container-pad">
      <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">Certificates</p>
      <h1 class="mt-3 max-w-3xl text-5xl font-black leading-tight text-ink">Trust documents and recognitions.</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-ink/72">Replace the placeholder certificate files with official scanned documents before launch.</p>
    </div>
  </section>
  <section class="py-16">
    <div class="container-pad grid gap-6 md:grid-cols-2">
      {certificates.map((certificate) => (
        <article class="rounded-lg border border-ink/10 bg-white p-5 shadow-sm">
          {certificate.data.image && <img src={certificate.data.image} alt={certificate.data.title.en} class="aspect-[1.4] w-full rounded-md object-cover" />}
          <h2 class="mt-5 text-2xl font-black text-ink">{certificate.data.title.en}</h2>
          {certificate.data.title.te && <p class="telugu mt-2 font-semibold text-leaf-700">{certificate.data.title.te}</p>}
          <p class="mt-3 text-sm text-ink/70">{certificate.data.issuer}</p>
          <a href={certificate.data.file} class="mt-4 inline-flex rounded-md border border-leaf-700 px-4 py-2 text-sm font-extrabold text-leaf-700 hover:bg-leaf-50">View document</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
