---
import { getEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBase } from "../lib/url";

const donation = await getEntry("donationSettings", "main");
---

<BaseLayout title="Donate | Seetayya Foundation" description="Donate to Seetayya Foundation through Razorpay, UPI, or bank transfer. Support daily food, shelter, medical care, and sponsor-day service." image="/uploads/events/donate-us-photo.jpg">
  <section class="bg-white py-16">
    <div class="container-pad grid gap-10 lg:grid-cols-[1fr_0.85fr] lg:items-center">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-saffron-700">Donate</p>
        <h1 class="mt-3 text-5xl font-black leading-tight text-ink">Support food, shelter, and daily care.</h1>
        <p class="telugu mt-4 text-lg font-semibold text-leaf-700">ఆహారం, ఆశ్రయం, నిత్య సంరక్షణకు మీ సహాయం అందించండి.</p>
        <p class="mt-6 text-lg leading-8 text-ink/72">
          This static site does not store donor payment data. Razorpay remains the online donation record system, and direct UPI/bank transfers are handled through the foundation team.
        </p>
      </div>
      <img src={withBase("/uploads/events/donate-us-photo.jpg")} alt="Donation support for Seetayya Foundation" class="rounded-lg object-cover shadow-soft" />
    </div>
  </section>

  <section class="py-16">
    <div class="container-pad grid gap-6 lg:grid-cols-3">
      <article class="rounded-lg border border-ink/10 bg-white p-6 shadow-sm lg:col-span-1">
        <h2 class="text-2xl font-black text-ink">Online donation</h2>
        <p class="mt-3 text-sm leading-6 text-ink/70">Use Razorpay hosted checkout for UPI, cards, netbanking, and supported payment methods.</p>
        <a href={donation!.data.razorpayPaymentLink ?? "#"} class="mt-6 inline-flex w-full items-center justify-center rounded-md bg-leaf-700 px-5 py-3 text-sm font-extrabold text-white transition hover:bg-leaf-900">
          Open Razorpay
        </a>
        <p class="mt-3 text-xs leading-5 text-ink/55">Update the Razorpay hosted payment link in `src/content/donationSettings/main.json` or `/admin`.</p>
      </article>

      <article class="rounded-lg border border-ink/10 bg-white p-6 shadow-sm lg:col-span-1">
        <h2 class="text-2xl font-black text-ink">UPI</h2>
        <img src={withBase(donation!.data.qrImage)} alt="UPI QR code for Seetayya Foundation" class="mx-auto mt-4 aspect-square w-56 rounded-md border border-ink/10 bg-white p-3" />
        <dl class="mt-5 grid gap-2 text-sm">
          <div class="flex justify-between gap-4"><dt class="font-bold text-ink">UPI ID</dt><dd class="text-right text-ink/70">{donation!.data.upiId}</dd></div>
          <div class="flex justify-between gap-4"><dt class="font-bold text-ink">Name</dt><dd class="text-right text-ink/70">{donation!.data.upiName}</dd></div>
        </dl>
      </article>

      <article class="rounded-lg border border-ink/10 bg-white p-6 shadow-sm lg:col-span-1">
        <h2 class="text-2xl font-black text-ink">Bank transfer</h2>
        <dl class="mt-5 grid gap-3 text-sm">
          <div><dt class="font-bold text-ink">Account name</dt><dd class="text-ink/70">{donation!.data.accountName}</dd></div>
          <div><dt class="font-bold text-ink">Bank</dt><dd class="text-ink/70">{donation!.data.bankName}</dd></div>
          <div><dt class="font-bold text-ink">Account number</dt><dd class="text-ink/70">{donation!.data.accountNumber}</dd></div>
          <div><dt class="font-bold text-ink">IFSC</dt><dd class="text-ink/70">{donation!.data.ifsc}</dd></div>
        </dl>
      </article>
    </div>
    <div class="container-pad mt-6 rounded-lg border border-saffron-100 bg-saffron-50 p-5 text-sm leading-6 text-ink/75">
      <p>{donation!.data.receiptNote.en}</p>
      <p class="telugu mt-2">{donation!.data.receiptNote.te}</p>
    </div>
  </section>
</BaseLayout>
