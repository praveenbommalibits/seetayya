---
import { getEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBase } from "../lib/url";
import { contactInfo } from "../data/site";

const donation = await getEntry("donationSettings", "main");
const hasPaymentLink = Boolean(donation?.data.razorpayPaymentLink);
const hasUpi = Boolean(donation?.data.upiId);
const hasBank = Boolean(donation?.data.accountNumber || donation?.data.ifsc || donation?.data.bankName);
---

<BaseLayout title="Donate | Seetayya Foundation" description="Support Seetayya Foundation through verified donation channels. Contact the foundation for confirmed online donation, UPI, or bank details." image="/uploads/events/donate-us-photo.jpg">
  <section class="bg-white py-16">
    <div class="container-pad grid gap-10 lg:grid-cols-[1fr_0.85fr] lg:items-center">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-saffron-700">Donate</p>
        <h1 class="mt-3 text-5xl font-black leading-tight text-ink">Support food, shelter, and daily care.</h1>
        <p class="telugu mt-4 text-lg font-semibold text-leaf-700">ఆహారం, ఆశ్రయం, నిత్య సంరక్షణకు మీ సహాయం అందించండి.</p>
        <p class="mt-6 text-lg leading-8 text-ink/72">The old website used an online GiveWP/Razorpay donation flow. This page shows only donation information that is verified for public display.</p>
      </div>
      <img src={withBase("/uploads/events/donate-us-photo.jpg")} alt="Donation support for Seetayya Foundation" class="rounded-lg object-cover shadow-soft" />
    </div>
  </section>

  <section class="py-16">
    <div class="container-pad grid gap-6 lg:grid-cols-3">
      <article class="rounded-lg border border-ink/10 bg-white p-6 shadow-sm lg:col-span-1">
        <h2 class="text-2xl font-black text-ink">Online donation</h2>
        <p class="mt-3 text-sm leading-6 text-ink/70">The old donation page uses an online payment gateway, but no reusable public Razorpay payment link was exposed in the old page content.</p>
        {hasPaymentLink ? (
          <a href={donation!.data.razorpayPaymentLink} class="mt-6 inline-flex w-full items-center justify-center rounded-md bg-leaf-700 px-5 py-3 text-sm font-extrabold text-white transition hover:bg-leaf-900">
            Open Razorpay
          </a>
        ) : (
          <p class="mt-6 rounded-md border border-saffron-100 bg-saffron-50 p-4 text-sm font-bold leading-6 text-ink/75">
            Please contact the foundation before making an online donation.
          </p>
        )}
      </article>

      <article class="rounded-lg border border-ink/10 bg-white p-6 shadow-sm lg:col-span-1">
        <h2 class="text-2xl font-black text-ink">UPI</h2>
        {hasUpi ? (
          <>
            {donation!.data.qrImage && <img src={withBase(donation!.data.qrImage)} alt="UPI QR code for Seetayya Foundation" class="mx-auto mt-4 aspect-square w-56 rounded-md border border-ink/10 bg-white p-3" />}
            <dl class="mt-5 grid gap-2 text-sm">
              <div class="flex justify-between gap-4"><dt class="font-bold text-ink">UPI ID</dt><dd class="text-right text-ink/70">{donation!.data.upiId}</dd></div>
              {donation!.data.upiName && <div class="flex justify-between gap-4"><dt class="font-bold text-ink">Name</dt><dd class="text-right text-ink/70">{donation!.data.upiName}</dd></div>}
            </dl>
          </>
        ) : (
          <p class="mt-3 text-sm leading-6 text-ink/70">No verified UPI ID or QR code was found in the old public content.</p>
        )}
      </article>

      <article class="rounded-lg border border-ink/10 bg-white p-6 shadow-sm lg:col-span-1">
        <h2 class="text-2xl font-black text-ink">Bank transfer</h2>
        {hasBank ? (
          <dl class="mt-5 grid gap-3 text-sm">
            {donation!.data.accountName && <div><dt class="font-bold text-ink">Account name</dt><dd class="text-ink/70">{donation!.data.accountName}</dd></div>}
            {donation!.data.bankName && <div><dt class="font-bold text-ink">Bank</dt><dd class="text-ink/70">{donation!.data.bankName}</dd></div>}
            {donation!.data.accountNumber && <div><dt class="font-bold text-ink">Account number</dt><dd class="text-ink/70">{donation!.data.accountNumber}</dd></div>}
            {donation!.data.ifsc && <div><dt class="font-bold text-ink">IFSC</dt><dd class="text-ink/70">{donation!.data.ifsc}</dd></div>}
          </dl>
        ) : (
          <p class="mt-3 text-sm leading-6 text-ink/70">No verified public bank details were found in the old website content.</p>
        )}
      </article>
    </div>
    <div class="container-pad mt-6 rounded-lg border border-saffron-100 bg-saffron-50 p-5 text-sm leading-6 text-ink/75">
      <p>{donation!.data.receiptNote.en}</p>
      <p class="telugu mt-2">{donation!.data.receiptNote.te}</p>
      <p class="mt-3 font-bold">Contact: {contactInfo.email} / {contactInfo.phones.join(" / ")}</p>
    </div>
  </section>
</BaseLayout>
