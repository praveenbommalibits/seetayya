---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import EventCard from "@components/EventCard.astro";

const events = (await getCollection("events"))
  .filter((entry) => entry.data.published)
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
---

<BaseLayout title="Events | Seetayya Foundation" description="Recent Seetayya Foundation events, health camps, awareness programmes, service activities, and celebrations.">
  <section class="bg-white py-16">
    <div class="container-pad">
      <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">Events</p>
      <h1 class="mt-3 max-w-3xl text-5xl font-black leading-tight text-ink">Activities that keep the community connected.</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-ink/72">Staff can publish new events from `/admin`; each event is stored as a Markdown file and rendered into this archive.</p>
    </div>
  </section>
  <section class="py-16">
    <div class="container-pad grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {events.map((event) => (
        <EventCard
          href={`/events/${event.slug}`}
          title={event.data.title}
          summary={event.data.summary}
          date={event.data.date}
          category={event.data.category}
          image={event.data.coverImage}
        />
      ))}
    </div>
  </section>
</BaseLayout>
