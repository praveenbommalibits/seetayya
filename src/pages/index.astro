---
import { redirectTargetForPreferredLocale } from "../lib/i18n";

const fallback = redirectTargetForPreferredLocale();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${fallback}`} />
    <link rel="canonical" href={fallback} />
    <title>Seetayya Foundation</title>
    <script is:inline define:vars={{ base }}>
      const saved = window.localStorage.getItem("seetayya-locale");
      const locale = saved === "te" || navigator.language.toLowerCase().startsWith("te") ? "te" : "en";
      window.location.replace(`${base}/${locale}`);
    </script>
  </head>
  <body>
    <p><a href={fallback}>Continue to Seetayya Foundation</a></p>
  </body>
</html>
