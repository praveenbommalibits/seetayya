---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import DonationCta from "@components/DonationCta.astro";
import EventCard from "@components/EventCard.astro";
import SponsorCard from "@components/SponsorCard.astro";
import { withBase } from "../lib/url";

const events = (await getCollection("events"))
  .filter((entry) => entry.data.published)
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
const sponsors = (await getCollection("dailySponsors"))
  .filter((entry) => entry.data.published)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const testimonials = (await getCollection("testimonials")).filter((entry) => entry.data.published);
const certificates = (await getCollection("certificates")).filter((entry) => entry.data.published);

const latestSponsor = sponsors[0];
const featuredEvents = events.filter((entry) => entry.data.featured).slice(0, 3);
---

<BaseLayout
  title="Seetayya Foundation | Food, shelter, and care"
  description="Seetayya Foundation supports elders, orphans, differently abled children, and people in need through daily food, shelter, medical care, and community service."
>
  <section class="relative min-h-[calc(100svh-5rem)] overflow-hidden bg-ink text-white">
    <img src={withBase("/uploads/events/founders.jpg")} alt="Seetayya Foundation service gathering" class="absolute inset-0 h-full w-full object-cover opacity-45" />
    <div class="absolute inset-0 bg-ink/45"></div>
    <div class="container-pad relative grid min-h-[calc(100svh-5rem)] items-end pb-12 pt-24 md:pb-16">
      <div class="max-w-3xl">
        <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-saffron-100">Seetayya Foundation</p>
        <h1 class="mt-4 text-5xl font-black leading-[1.02] md:text-7xl">
          Welcome To Seetayya Foundation
        </h1>
        <p class="telugu mt-5 max-w-2xl text-lg font-semibold text-white/88">
          వృద్ధులు, అనాధలు, దివ్యాంగ పిల్లలు, అవసరంలో ఉన్నవారికి ఆహారం, ఆశ్రయం, సంరక్షణ.
        </p>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/82">
          A nonprofit organization committed to serving the elderly, the disabled, and orphans through shelter, food, and a peaceful family environment.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={withBase("/donate")} class="inline-flex items-center justify-center rounded-md bg-saffron-500 px-6 py-3 text-sm font-extrabold text-ink transition hover:bg-saffron-100">
            Donate now
          </a>
          <a href={withBase("/sponsor-a-day")} class="inline-flex items-center justify-center rounded-md border border-white/40 px-6 py-3 text-sm font-extrabold text-white transition hover:bg-white/10">
            Sponsor food for a day
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-10">
    <div class="container-pad grid gap-4 md:grid-cols-4">
      {[
        ["2019", "Service initiative"],
        ["2", "Buildings constructed"],
        ["4+ years", "Old-age home services"],
        ["Reg: 440-2019", "Foundation registration"]
      ].map(([value, label]) => (
        <div class="rounded-lg border border-ink/10 p-5">
          <p class="text-3xl font-black text-leaf-700">{value}</p>
          <p class="mt-1 text-sm font-semibold text-ink/65">{label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-16">
    <div class="container-pad grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">What we do</p>
        <h2 class="mt-3 text-4xl font-black leading-tight text-ink">A home built by the founders for service.</h2>
        <p class="mt-5 text-lg leading-8 text-ink/72">
          Gulla Ramesh and Gulla Mohanarao, sons of late Sri Gulla Seetayya garu, bought land in Sompeta village from their hard-earned savings and donated part of it to serve old-age people and orphan people.
        </p>
        <p class="telugu mt-4 text-ink/70">
          ప్రతి రోజు ఆహారం, ఆశ్రయం, ఆరోగ్య సహాయం, ఆప్యాయతతో కూడిన సేవ అందించడమే మా లక్ష్యం.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {[
          ["Vanaprastha Ashramam", "One of the two buildings constructed with donations and donor support."],
          ["Nityannadana Nilayam", "A dedicated space connected to daily food service and care."],
          ["Health camps", "Blood donation, eye care, medical, yoga, and awareness activities from the old site."],
          ["Rehabilitation project", "A planned center for differently abled children in the foundation premises."]
        ].map(([title, text]) => (
          <div class="rounded-lg border border-ink/10 bg-white p-6 shadow-sm">
            <h3 class="text-xl font-extrabold text-ink">{title}</h3>
            <p class="mt-3 text-sm leading-6 text-ink/68">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {latestSponsor && (
    <section class="bg-saffron-50 py-16">
      <div class="container-pad grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
        <div>
          <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-saffron-700">Latest sponsor-day update</p>
          <h2 class="mt-3 text-4xl font-black leading-tight text-ink">Food support, recorded with gratitude.</h2>
          <p class="mt-4 text-ink/70">
            Verified public sponsor-day entries will appear here after the foundation confirms the details.
          </p>
        </div>
        <SponsorCard {...latestSponsor.data} />
      </div>
    </section>
  )}

  <section class="py-16">
    <div class="container-pad">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">Latest activities</p>
          <h2 class="mt-3 text-4xl font-black text-ink">Recent service stories</h2>
        </div>
        <a href={withBase("/events")} class="text-sm font-extrabold text-leaf-700 underline">View all events</a>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {featuredEvents.map((event) => (
          <EventCard
            href={`/events/${event.slug}`}
            title={event.data.title}
            summary={event.data.summary}
            date={event.data.date}
            category={event.data.category}
            image={event.data.coverImage}
          />
        ))}
      </div>
    </div>
  </section>

  <DonationCta />

  <section class="bg-white py-16">
    <div class="container-pad grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">Trust and transparency</p>
        <h2 class="mt-3 text-4xl font-black leading-tight text-ink">Certificates and old-site community voices.</h2>
        <p class="mt-4 text-ink/70">
          The old website shares registration and tax-related certificate information along with visitor testimonials.
        </p>
      </div>
      <div class="grid gap-4">
        {testimonials.slice(0, 3).map((entry) => (
          <figure class="rounded-lg border border-ink/10 bg-mist p-5">
            <blockquote class="text-sm leading-6 text-ink/74">"{entry.data.quote.en}"</blockquote>
            <figcaption class="mt-3 text-sm font-extrabold text-ink">{entry.data.name}</figcaption>
          </figure>
        ))}
        <div class="grid gap-3 sm:grid-cols-2">
          {certificates.slice(0, 2).map((certificate) => (
            <a href={withBase("/certificates")} class="rounded-lg border border-ink/10 p-4 text-sm font-extrabold text-leaf-700 hover:bg-leaf-50">
              {certificate.data.title.en}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
