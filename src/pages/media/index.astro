---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBase } from "../../lib/url";

const albums = (await getCollection("albums"))
  .filter((entry) => entry.data.published)
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));
---

<BaseLayout title="Media | Seetayya Foundation" description="Photo albums from Seetayya Foundation events, daily care, and service programmes.">
  <section class="bg-white py-16">
    <div class="container-pad">
      <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">Media</p>
      <h1 class="mt-3 max-w-3xl text-5xl font-black leading-tight text-ink">Foundation photo albums.</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-ink/72">The old website includes galleries from foundation activities, care work, service events, and community programs.</p>
    </div>
  </section>
  <section class="py-16">
    <div class="container-pad grid gap-6 md:grid-cols-2">
      {albums.map((album) => (
        <a href={withBase(`/media/${album.slug}`)} class="group overflow-hidden rounded-lg border border-ink/10 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
          <div class="aspect-[16/10] overflow-hidden bg-leaf-50">
            <img src={withBase(album.data.coverImage)} alt={album.data.title.en} loading="lazy" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
          </div>
          <div class="p-6">
            <p class="text-sm font-extrabold uppercase tracking-wide text-leaf-700">{album.data.category}</p>
            <h2 class="mt-2 text-2xl font-black text-ink">{album.data.title.en}</h2>
            {album.data.title.te && <p class="telugu mt-2 font-semibold text-ink/68">{album.data.title.te}</p>}
            <p class="mt-4 text-sm leading-6 text-ink/70">{album.data.summary.en}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
