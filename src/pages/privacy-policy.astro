---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy | Seetayya Foundation" description="Privacy policy for the static Seetayya Foundation website.">
  <section class="bg-white py-16">
    <div class="container-pad max-w-3xl">
      <h1 class="text-5xl font-black text-ink">Privacy Policy</h1>
      <div class="rich-content mt-8 text-lg leading-8 text-ink/74">
        <p>This static website does not use a custom database to store donor, volunteer, or contact information.</p>
        <p>Donation records are handled by the selected payment provider or by the foundation team for direct bank/UPI transfers. Contact and volunteer messages are handled through email.</p>
        <p>Photos, sponsor names, certificates, articles, and event details shown on the website are public content managed by the foundation team through repository files.</p>
      </div>
    </div>
  </section>
</BaseLayout>
