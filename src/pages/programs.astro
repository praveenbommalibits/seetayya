---
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBase } from "../lib/url";

const programs = [
  {
    title: "Old-age home service",
    te: "వృద్ధాశ్రమ సేవలు",
    text: "The old website says the foundation has provided old-age home services for more than four years, with shelter, food, care, and a peaceful environment.",
    href: "/about"
  },
  {
    title: "Orphan and needy care",
    te: "అనాధలకు ఆశ్రయం",
    text: "Seetayya Foundation supports orphan people and people who do not have dependable family care, including daily food and shelter.",
    href: "/about"
  },
  {
    title: "Special school and rehabilitation",
    te: "ప్రత్యేక పాఠశాల మరియు పునరావాసం",
    text: "The old website lists a special school and rehabilitation center for mentally challenged and differently abled children.",
    href: "/rehabilitation-center"
  },
  {
    title: "Blood donation camps",
    te: "రక్తదాన శిబిరాలు",
    text: "The foundation highlights mega blood donation camps, including a camp organized with Helping Hands.",
    href: "/events"
  },
  {
    title: "Medical and eye care camps",
    te: "వైద్య మరియు కంటి పరీక్షలు",
    text: "Old-site activities include free medical camps, eye checkups, and free eye operations supported by Sompeta Aarogyavaram doctors.",
    href: "/events"
  },
  {
    title: "Public awareness programs",
    te: "ఆరోగ్య మరియు అవగాహన శిబిరాలు",
    text: "The old homepage includes legal awareness, Yoga Day celebrations, and community service events.",
    href: "/events"
  },
  {
    title: "Water, cow care, and medical support",
    te: "నీటి పంపిణీ మరియు వైద్య సహాయం",
    text: "The Vision & Mission page mentions drinking water distribution, cow care, paralysis victim medical care, and support for kidney disease needs.",
    href: "/vision-mission"
  },
  {
    title: "Self-employment programs",
    te: "స్వయం ఉపాధి కార్యక్రమాలు",
    text: "The old Vision & Mission page includes self-employment programs for young women as one of the foundation activities.",
    href: "/vision-mission"
  },
  {
    title: "Daily food support",
    te: "నిత్య అన్నదానం",
    text: "The foundation constructed Seetayya Foundation Nityannadana Nilayam with donor support to serve daily food needs.",
    href: "/events"
  }
];
---

<BaseLayout title="Programs | Seetayya Foundation" description="Explore Seetayya Foundation programmes including daily annadanam, elder care, rehabilitation support, and health awareness camps.">
  <section class="bg-white py-16">
    <div class="container-pad">
      <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">Programs</p>
      <h1 class="mt-3 max-w-3xl text-5xl font-black leading-tight text-ink">Service areas from the old foundation website.</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-ink/72">These programs are based on the old About, Vision & Mission, Ongoing Projects, and homepage activity sections.</p>
    </div>
  </section>
  <section class="py-16">
    <div class="container-pad grid gap-6 md:grid-cols-2">
      {programs.map((program) => (
        <a href={withBase(program.href)} class="rounded-lg border border-ink/10 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
          <h2 class="text-2xl font-black text-ink">{program.title}</h2>
          <p class="telugu mt-2 font-semibold text-leaf-700">{program.te}</p>
          <p class="mt-4 text-sm leading-6 text-ink/70">{program.text}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
