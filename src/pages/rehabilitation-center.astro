---
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBase } from "../lib/url";
---

<BaseLayout title="Special School & Rehabilitation Center | Seetayya Foundation" description="A dedicated programme for mentally challenged and differently abled children, focused on care, dignity, routines, and community support." image="/uploads/events/residents-care.jpg">
  <section class="bg-white py-16">
    <div class="container-pad grid gap-10 lg:grid-cols-[1fr_1fr] lg:items-center">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">Special care</p>
        <h1 class="mt-3 text-5xl font-black leading-tight text-ink">Special School & Rehabilitation Center</h1>
        <p class="telugu mt-4 text-lg font-semibold text-leaf-700">దివ్యాంగ పిల్లల సంరక్షణ మరియు పునరావాస సహాయం</p>
        <p class="mt-6 text-lg leading-8 text-ink/72">
          This page replaces the old WordPress rehabilitation page with a clearer, responsive presentation. Staff can add photos and updates through events and albums while keeping personal child information private.
        </p>
      </div>
      <img src={withBase("/uploads/events/residents-care.jpg")} alt="Care support at Seetayya Foundation" class="rounded-lg object-cover shadow-soft" />
    </div>
  </section>
  <section class="py-16">
    <div class="container-pad grid gap-5 md:grid-cols-3">
      {[
        ["Routine", "Daily care, meals, supervised activities, and calm support."],
        ["Dignity", "No public private records or sensitive child information in v1."],
        ["Community", "Volunteers and donors can support materials, meals, and activities."]
      ].map(([title, text]) => (
        <article class="rounded-lg border border-ink/10 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-extrabold text-ink">{title}</h2>
          <p class="mt-3 text-sm leading-6 text-ink/70">{text}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
