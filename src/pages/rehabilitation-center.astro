---
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBase } from "../lib/url";
---

<BaseLayout title="Special School & Rehabilitation Center | Seetayya Foundation" description="Seetayya Foundation project page for a special school and rehabilitation center serving mentally challenged and differently abled children." image="/uploads/events/residents-care.jpg">
  <section class="bg-white py-16">
    <div class="container-pad grid gap-10 lg:grid-cols-[1fr_1fr] lg:items-center">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">Rehabilitation center</p>
        <h1 class="mt-3 text-5xl font-black leading-tight text-ink">Special School & Rehabilitation Center</h1>
        <p class="telugu mt-4 text-lg font-semibold text-leaf-700">దివ్యాంగ పిల్లల సంరక్షణ మరియు పునరావాస సహాయం</p>
        <p class="mt-6 text-lg leading-8 text-ink/72">
          The old website lists this as a special school and rehabilitation center for mentally challenged children. It also describes a new project to construct a physically handicapped children's rehabilitation center in the foundation premises.
        </p>
      </div>
      <img src={withBase("/uploads/events/residents-care.jpg")} alt="Care support at Seetayya Foundation" class="rounded-lg object-cover shadow-soft" />
    </div>
  </section>
  <section class="py-16">
    <div class="container-pad grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <h2 class="text-3xl font-black leading-tight text-ink">New project from the old website</h2>
        <p class="mt-4 text-sm leading-6 text-ink/70">
          Seetayya Foundation says the need for dedicated support has grown as elderly people, orphans, mentally challenged people, and differently abled people continue reaching the ashram. The foundation requested donors to participate in the construction of a center with special facilities for differently abled children.
        </p>
        <p class="mt-4 text-sm font-bold text-leaf-700">Foundation registration reference: REG:440-2019</p>
      </div>
      <div class="telugu rounded-lg border border-ink/10 bg-white p-6 text-base leading-8 text-ink/75 shadow-sm">
        <p>
          "సీతయ్య ఫౌండేషన్" వృద్ధాశ్రమం ప్రాంగణంలో "దివ్యాంగుల సేవార్ధం" Physically Handicapped Children's Rehabilitation Centre నూతన భవన నిర్మాణం కోసం పాత వెబ్‌సైట్‌లో విజ్ఞప్తి ప్రచురించబడింది.
        </p>
        <p class="mt-4">
          2019లో ప్రారంభమైన ఫౌండేషన్ సేవలు అనాథ వృద్ధులు, మానసిక వికలాంగులు, దివ్యాంగులు మరియు ఆశ్రయం అవసరమైన వారికి కొనసాగుతున్నాయని పాత ప్రాజెక్ట్ పేజీ పేర్కొంటుంది.
        </p>
      </div>
    </div>
  </section>
  <section class="bg-white py-16">
    <div class="container-pad grid gap-5 md:grid-cols-3">
      {[
        ["Special facilities", "The old project page calls for dedicated facilities for differently abled children."],
        ["Ongoing service", "The foundation describes continuing service for elders, orphans, mentally challenged people, and differently abled people."],
        ["Donor participation", "The old page requests charitable donors to take part in the rehabilitation center construction."]
      ].map(([title, text]) => (
        <article class="rounded-lg border border-ink/10 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-extrabold text-ink">{title}</h2>
          <p class="mt-3 text-sm leading-6 text-ink/70">{text}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
