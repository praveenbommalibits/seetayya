---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import SponsorCard from "@components/SponsorCard.astro";
import DonationCta from "@components/DonationCta.astro";
import { withBase } from "../lib/url";

const sponsors = (await getCollection("dailySponsors"))
  .filter((entry) => entry.data.published)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Sponsor a Day | Seetayya Foundation" description="Support daily food and annadanam at Seetayya Foundation. Verified sponsor-day entries will be shown when the foundation provides public details." image="/uploads/events/residents-care.jpg">
  <section class="bg-white py-16">
    <div class="container-pad grid gap-10 lg:grid-cols-[1fr_0.8fr] lg:items-center">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-saffron-700">Sponsor a Day</p>
        <h1 class="mt-3 text-5xl font-black leading-tight text-ink">Support daily food and care.</h1>
        <p class="telugu mt-4 text-lg font-semibold text-leaf-700">ఒక రోజు అన్నదానం ద్వారా సేవ చేయండి.</p>
        <p class="mt-6 text-lg leading-8 text-ink/72">The old website highlights Seetayya Foundation Nityannadana Nilayam and requests donor support for people staying at the foundation. Verified sponsor-day entries will be published here only when the foundation provides public details.</p>
      </div>
      <img src={withBase("/uploads/events/residents-care.jpg")} alt="Daily care and annadanam" class="rounded-lg object-cover shadow-soft" />
    </div>
  </section>
  <section class="py-16">
    <div class="container-pad">
      <h2 class="text-3xl font-black text-ink">Recent sponsor-day entries</h2>
      {sponsors.length > 0 ? (
        <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {sponsors.map((sponsor) => <SponsorCard {...sponsor.data} />)}
        </div>
      ) : (
        <div class="mt-8 rounded-lg border border-ink/10 bg-white p-6 text-sm leading-6 text-ink/70 shadow-sm">
          No verified public sponsor-day entries were available from the old website content. The foundation can publish real entries here after confirming the sponsor name, date, meal type, and permission to display photos.
        </div>
      )}
    </div>
  </section>
  <DonationCta compact />
</BaseLayout>
