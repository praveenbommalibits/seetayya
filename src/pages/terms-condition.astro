---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Terms & Condition | Seetayya Foundation" description="Terms and conditions for Seetayya Foundation website usage and donations.">
  <section class="bg-white py-16">
    <div class="container-pad max-w-3xl">
      <h1 class="text-5xl font-black text-ink">Terms & Condition</h1>
      <div class="rich-content mt-8 text-lg leading-8 text-ink/74">
        <p>This website provides public information about Seetayya Foundation programmes, events, sponsor-day activities, certificates, and donation options.</p>
        <p>Donation links may route visitors to Razorpay or other payment systems managed outside this static website. Donors should verify payment details before making a contribution.</p>
        <p>Foundation staff should publish only approved public content and avoid adding sensitive personal resident details to the site.</p>
      </div>
    </div>
  </section>
</BaseLayout>
