---
import { getEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

const page = await getEntry("pages", "vision-mission");
const { Content } = await page!.render();
---

<BaseLayout title="Vision & Mission | Seetayya Foundation" description={page!.data.description.en} image={page!.data.heroImage}>
  <section class="relative overflow-hidden bg-ink text-white">
    <img src={page!.data.heroImage} alt="Daily care at Seetayya Foundation" class="absolute inset-0 h-full w-full object-cover opacity-35" />
    <div class="container-pad relative py-20">
      <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-saffron-100">Vision & Mission</p>
      <h1 class="mt-3 max-w-3xl text-5xl font-black leading-tight">{page!.data.title.en}</h1>
      <p class="telugu mt-4 max-w-2xl text-lg font-semibold text-white/86">{page!.data.description.te}</p>
    </div>
  </section>
  <section class="py-16">
    <div class="container-pad grid gap-8 lg:grid-cols-2">
      <article class="rounded-lg border border-ink/10 bg-white p-8 shadow-sm">
        <h2 class="text-3xl font-black text-ink">Vision</h2>
        <p class="mt-4 text-lg leading-8 text-ink/72">No person should be left without food, shelter, and humane care because they lack family support.</p>
      </article>
      <article class="rounded-lg border border-ink/10 bg-white p-8 shadow-sm">
        <h2 class="text-3xl font-black text-ink">Mission</h2>
        <div class="rich-content mt-4 text-lg leading-8 text-ink/72"><Content /></div>
      </article>
    </div>
  </section>
</BaseLayout>
