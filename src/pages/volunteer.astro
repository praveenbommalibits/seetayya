---
import BaseLayout from "@layouts/BaseLayout.astro";
const email = "seetayyafoundation@example.org";
---

<BaseLayout title="Volunteer | Seetayya Foundation" description="Volunteer with Seetayya Foundation for service visits, health camps, food service, media support, and community activities.">
  <section class="bg-white py-16">
    <div class="container-pad grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf-700">Volunteer</p>
        <h1 class="mt-3 text-5xl font-black leading-tight text-ink">Give time with care and responsibility.</h1>
        <p class="mt-5 text-lg leading-8 text-ink/72">Use this form to open an email to the foundation team. No volunteer details are stored by the website.</p>
      </div>
      <form action={`mailto:${email}`} method="post" enctype="text/plain" class="rounded-lg border border-ink/10 bg-mist p-6 shadow-sm">
        <div class="grid gap-4">
          <label class="grid gap-2 text-sm font-bold text-ink">Name <input name="Name" required class="rounded-md border border-ink/15 px-3 py-3 font-normal" /></label>
          <label class="grid gap-2 text-sm font-bold text-ink">Phone <input name="Phone" required class="rounded-md border border-ink/15 px-3 py-3 font-normal" /></label>
          <label class="grid gap-2 text-sm font-bold text-ink">Email <input type="email" name="Email" class="rounded-md border border-ink/15 px-3 py-3 font-normal" /></label>
          <label class="grid gap-2 text-sm font-bold text-ink">How would you like to help? <textarea name="Volunteer interest" rows="5" class="rounded-md border border-ink/15 px-3 py-3 font-normal"></textarea></label>
          <button class="rounded-md bg-leaf-700 px-5 py-3 text-sm font-extrabold text-white transition hover:bg-leaf-900">Email volunteer request</button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
